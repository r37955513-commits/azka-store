# قاعدة بيانات Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# كلمة مرور لوحة تحكم الأدمن
ADMIN_PASSWORD="change-me-strong-password"

# سرّ توقيع الجلسات (أي نص عشوائي طويل)
SESSION_SECRET="super-secret-session-key-change-me"

# Vercel Blob — لتخزين صور إشعارات التحويل (مطلوب على Vercel)
# يُنشأ تلقائياً عند إنشاء Blob Store من لوحة Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# WhatsApp Cloud API (Meta) لإرسال إشعارات الأدمن
WHATSAPP_TOKEN="EAAG..."
WHATSAPP_PHONE_ID="123456789012345"
ADMIN_WHATSAPP_NUMBER="2499xxxxxxxx"
# توكن التحقق من webhook (أي نص تختاره وتضعه أيضاً في إعداد Meta)
WHATSAPP_VERIFY_TOKEN="my-verify-token"

# منفذ التشغيل (للتشغيل الذاتي عبر خادم Hono فقط — غير مستخدم على Vercel)
PORT=3000
